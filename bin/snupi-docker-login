#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: snupi-docker-login [--registry docker.io]

Persist Docker registry auth in the DDN-backed reservation workspace.

Default behavior:
  - writes auth to ~/work/.docker/config.json
  - links ~/.docker -> ~/work/.docker

This is for build/push auth inside an already-running pod.
EOF
}

die() {
  echo "snupi-docker-login: $*" >&2
  exit 1
}

info() {
  echo "snupi-docker-login: $*"
}

backup_path() {
  local path="$1"
  local timestamp backup
  timestamp="$(date +%Y%m%d%H%M%S)"
  backup="${path}.snupi-backup-${timestamp}"
  while [ -e "$backup" ] || [ -L "$backup" ]; do
    timestamp="${timestamp}.$RANDOM"
    backup="${path}.snupi-backup-${timestamp}"
  done
  mv "$path" "$backup"
  info "moved existing $path to $backup"
}

link_home_path() {
  local link_path="$1"
  local target_path="$2"
  local current_target

  mkdir -p "$(dirname "$link_path")"
  if [ -L "$link_path" ]; then
    current_target="$(readlink "$link_path")"
    if [ "$current_target" = "$target_path" ]; then
      return
    fi
    backup_path "$link_path"
  elif [ -e "$link_path" ]; then
    backup_path "$link_path"
  fi
  ln -s "$target_path" "$link_path"
  info "linked $link_path -> $target_path"
}

registry="docker.io"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --registry)
      shift || die "missing value for --registry"
      registry="$1"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
  shift
done

[ -n "${HOME:-}" ] || die "HOME is not set"

work_root="${HOME}/work"
if [ -d "$work_root" ]; then
  docker_config_dir="${work_root}/.docker"
  home_docker_config_dir="${HOME}/.docker"
else
  docker_config_dir="${HOME}/.docker"
  home_docker_config_dir=""
  info "warning: ~/work does not exist; auth will not be DDN-persistent"
fi

case "$registry" in
  docker.io|index.docker.io|https://index.docker.io/v1/)
    auth_key="https://index.docker.io/v1/"
    registry_label="Docker Hub"
    ;;
  *)
    auth_key="$registry"
    registry_label="$registry"
    ;;
esac

printf '%s username: ' "$registry_label"
read -r registry_username
[ -n "$registry_username" ] || die "username must not be blank"

printf '%s personal access token/password: ' "$registry_label"
read -r -s registry_token
printf '\n'
[ -n "$registry_token" ] || die "token/password must not be blank"

install -d -m 0700 "$docker_config_dir"
config_path="${docker_config_dir}/config.json"
auth_value="$(printf '%s:%s' "$registry_username" "$registry_token" | base64 | tr -d '\n')"

if command -v python3 >/dev/null 2>&1; then
  AUTH_KEY="$auth_key" AUTH_VALUE="$auth_value" CONFIG_PATH="$config_path" python3 - <<'PY'
import json
import os
from pathlib import Path

config_path = Path(os.environ["CONFIG_PATH"])
auth_key = os.environ["AUTH_KEY"]
auth_value = os.environ["AUTH_VALUE"]

raw = {}
if config_path.exists():
    try:
        raw = json.loads(config_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"existing Docker config is not valid JSON: {config_path}: {exc}")
if not isinstance(raw, dict):
    raise SystemExit(f"existing Docker config is not a JSON object: {config_path}")
auths = raw.setdefault("auths", {})
if not isinstance(auths, dict):
    raise SystemExit(f"existing Docker config auths is not a JSON object: {config_path}")
auths[auth_key] = {"auth": auth_value}
tmp_path = config_path.with_suffix(config_path.suffix + ".tmp")
tmp_path.write_text(json.dumps(raw, indent=2, sort_keys=True) + "\n", encoding="utf-8")
tmp_path.replace(config_path)
PY
else
  cat >"$config_path" <<EOF
{"auths":{"${auth_key}":{"auth":"${auth_value}"}}}
EOF
fi

chmod 0600 "$config_path"

if [ -n "$home_docker_config_dir" ]; then
  link_home_path "$home_docker_config_dir" "$docker_config_dir"
fi

info "saved auth for $auth_key to $config_path"
info "default Docker config path: ${HOME}/.docker/config.json"
