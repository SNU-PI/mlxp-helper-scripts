#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: snupi-git-setup [--protocol https|ssh] [--hostname github.com]

Persist GitHub auth in the DDN-backed reservation workspace.

Default:
  snupi-git-setup

The default HTTPS mode uses GitHub CLI as Git's credential helper. SSH mode
creates a persistent SSH key under ~/work/.ssh and attempts to upload it with gh.
EOF
}

die() {
  echo "snupi-git-setup: $*" >&2
  exit 1
}

info() {
  echo "snupi-git-setup: $*"
}

run_linker() {
  local script_dir linker
  script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
  linker="${script_dir}/snupi-link-persistent-configs"
  if [ -x "$linker" ]; then
    "$linker"
  elif command -v snupi-link-persistent-configs >/dev/null 2>&1; then
    snupi-link-persistent-configs
  else
    info "snupi-link-persistent-configs not found; skipping home link refresh"
  fi
}

configure_git_identity_if_missing() {
  if ! git config --global user.name >/dev/null 2>&1; then
    printf 'Git user.name (leave blank to skip): '
    read -r git_name
    if [ -n "$git_name" ]; then
      git config --global user.name "$git_name"
    fi
  fi
  if ! git config --global user.email >/dev/null 2>&1; then
    printf 'Git user.email (leave blank to skip): '
    read -r git_email
    if [ -n "$git_email" ]; then
      git config --global user.email "$git_email"
    fi
  fi
}

configure_ssh() {
  command -v ssh-keygen >/dev/null 2>&1 || die "ssh-keygen is not installed"
  command -v ssh >/dev/null 2>&1 || die "ssh is not installed"

  local ssh_dir="$snupi_ssh_dir"
  local key_path="${ssh_dir}/id_ed25519_github"
  local title="snupi-mlxp-${MLXP_USERNAME:-user}-$(hostname)-$(date +%Y%m%d)"

  install -d -m 0700 "$ssh_dir"
  if [ ! -f "$key_path" ]; then
    ssh-keygen -t ed25519 -C "${MLXP_USERNAME:-mlxp}@snupi-mlxp" -N "" -f "$key_path"
  fi
  chmod 0600 "$key_path"
  chmod 0644 "${key_path}.pub"

  cat >"${ssh_dir}/config" <<EOF
Host ${hostname}
  HostName ${hostname}
  User git
  IdentityFile ${key_path}
  IdentitiesOnly yes
EOF
  chmod 0600 "${ssh_dir}/config"
  run_linker

  if gh auth status --hostname "$hostname" >/dev/null 2>&1; then
    :
  else
    gh auth login --hostname "$hostname" --git-protocol ssh --web
  fi

  if gh ssh-key add "${key_path}.pub" --title "$title" >/dev/null 2>&1; then
    info "uploaded SSH public key to $hostname as: $title"
  else
    info "could not upload SSH key automatically; add this public key to GitHub:"
    cat "${key_path}.pub"
  fi

  info "test with: ssh -T git@${hostname}"
}

protocol="https"
hostname="github.com"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --protocol)
      shift || die "missing value for --protocol"
      protocol="$1"
      ;;
    --hostname)
      shift || die "missing value for --hostname"
      hostname="$1"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
  shift
done

case "$protocol" in
  https|ssh) ;;
  *) die "--protocol must be https or ssh" ;;
esac

[ -n "${HOME:-}" ] || die "HOME is not set"
command -v git >/dev/null 2>&1 || die "git is not installed"
command -v gh >/dev/null 2>&1 || die "gh is not installed"

if [ -d "${HOME}/work" ]; then
  gh_config_dir="${HOME}/work/.config/gh"
  snupi_ssh_dir="${HOME}/work/.ssh"
  git_config_global="${HOME}/work/.gitconfig"
else
  gh_config_dir="${HOME}/.config/gh"
  snupi_ssh_dir="${HOME}/.ssh"
  git_config_global="${HOME}/.gitconfig"
  info "warning: ~/work does not exist; GitHub auth will not be DDN-persistent"
fi

install -d -m 0700 "$gh_config_dir"
install -d -m 0700 "$(dirname "$git_config_global")"
touch "$git_config_global"
chmod 0600 "$git_config_global"
run_linker

configure_git_identity_if_missing

if [ "$protocol" = "https" ]; then
  if gh auth status --hostname "$hostname" >/dev/null 2>&1; then
    info "gh is already authenticated for $hostname"
  else
    gh auth login --hostname "$hostname" --git-protocol https --web
  fi
  gh auth setup-git --hostname "$hostname"
  info "configured Git to use gh credentials for $hostname"
else
  configure_ssh
fi

info "GitHub CLI config: $gh_config_dir"
info "global Git config: $git_config_global"
